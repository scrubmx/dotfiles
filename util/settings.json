{
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "catppuccin-icons.hidesExplorerArrows": false,
  "catppuccin-icons.monochrome": false,
  "catppuccin-icons.specificFolders": true,
  "composer.executablePath": "/Users/scrub/Library/Application\\ Support/Herd/bin//composer",
  "composer.ignorePlatformReqs": false,
  "crashReporting.enabled": "off",
  "cursor.composer.usageSummaryDisplay": "always",
  "cSpell.language": "en,es",
  "cSpell.userWords": [
    "nestjs",
    "timestamptz"
  ],
  "cSpell.customDictionaries": {
    "custom-dictionary-user": {
      "addWords": true,
      "name": "custom-dictionary-user",
      "path": "~/.config/cspell/custom-dictionary.txt",
      "scope": "user"
    }
  },
  "debug.console.fontSize": 15,
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {},
  "editor.defaultFoldingRangeProvider": "MohammadBaqer.better-folding",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.folding": true,
  "editor.foldingHighlight": false,
  "editor.foldingImportsByDefault": true,
  "editor.fontFamily": "'Monaspace Neon', 'Symbols Nerd Font Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": "'calt', 'liga', 'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss09', 'cv30', 'cv60'",
  "editor.fontSize": 15,
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.formatOnType": false,
  "editor.lineHeight": 1.5,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.multiCursorLimit": 1000,
  "editor.scrollbar.horizontalScrollbarSize": 10,
  "editor.scrollbar.verticalScrollbarSize": 8,
  "explicitFolding.autoFold": "2",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 4000,
  "git.blame.editorDecoration.enabled": false,
  "gitlens.currentLine.enabled": false,
  "intelephense.codeLens.implementations.enable": true,
  "intelephense.codeLens.overrides.enable": true,
  "intelephense.codeLens.parent.enable": true,
  "intelephense.codeLens.references.enable": true,
  "intelephense.codeLens.usages.enable": true,
  "intelephense.compatibility.preferPsalmPhpstanPrefixedAnnotations": true,
  "intelephense.inlayHint.returnTypes": true,
  "search.exclude": {
    "**/*.log": true,
    "**/*.tsbuildinfo": true,
    "**/.cache": true,
    "**/.eslintcache": true,
    "**/.nestjs_repl_history": true,
    "**/.next": true,
    "**/.swc": true,
    "**/.turbo": true,
    "**/.vercel": true,
    "**/build": true,
    "**/coverage": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/out": true,
    "**/storybook-static": true,
    "**/temp": true,
    "**/tmp": true,
    ".nestjs_repl_history": true
  },
  "scm.inputFontFamily": "'Monaspace Neon', 'Symbols Nerd Font Mono', Menlo, Monaco, 'Courier New', monospace",
  "scm.inputFontSize": 15,
  "security.promptForLocalFileProtocolHandling": false,
  "telemetry.feedback.enabled": false,
  "terminal.external.osxExec": "Ghostty.app",
  "terminal.integrated.fontFamily": "'Monaspace Neon', 'Symbols Nerd Font Mono', Menlo, Monaco, 'Courier New', monospace",
  "terminal.integrated.fontSize": 15,
  "terminal.integrated.lineHeight": 1.2,
  "terminal.integrated.fontLigatures.fallbackLigatures": [
    "<--",
    "<---",
    "<<-",
    "<-",
    "->",
    "->>",
    "-->",
    "--->",
    "<==",
    "<===",
    "<<=",
    "<=",
    "=>",
    "=>>",
    "==>",
    "===>",
    ">=",
    ">>=",
    "<->",
    "<-->",
    "<--->",
    "<---->",
    "<=>",
    "<==>",
    "<===>",
    "<====>",
    "::",
    ":::",
    "<~~",
    "</",
    "</>",
    "/>",
    "~~>",
    "==",
    "!=",
    "/=",
    "~=",
    "<>",
    "===",
    "!==",
    "!===",
    "<:",
    ":=",
    "*=",
    "*+",
    "<*",
    "<*>",
    "*>",
    "<|",
    "<|>",
    "|>",
    "+*",
    "=*",
    "=:",
    ":>",
    "/*",
    "*/",
    "+++",
    "<!--",
    "<!---"
  ],
  "terminal.integrated.scrollback": 5000,
  "update.releaseTrack": "dev",
  "update.mode": "silentlyApplyOnQuit",
  "vim.disableExtension": false,
  "vim.enableNeovim": true,
  "vim.highlightedyank.color": "rgb(127, 132, 156)",
  "vim.highlightedyank.enable": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.leader": ",",
  "vim.neovimPath": "/opt/homebrew/bin/nvim",
  "vim.statusBarColorControl": true,
  "vim.statusBarColors.normal": [
    "#89b4fa",
    "#020617"
  ],
  "vim.foldfix": true,
  "vim.statusBarColors.commandlineinprogress": "#fab387",
  "vim.statusBarColors.insert": "#a6e3a1",
  "vim.statusBarColors.replace": "#d08770",
  "vim.statusBarColors.searchinprogressmode": "#fab387",
  "vim.statusBarColors.visual": "#cba6f7",
  "vim.statusBarColors.visualblock": "#cba6f7",
  "vim.statusBarColors.visualline": "#cba6f7",
  "vim.useSystemClipboard": true,
  "window.autoDetectColorScheme": false,
  "window.commandCenter": true,
  "window.titleBarStyle": "custom",
  "window.zoomLevel": 0.2,
  "workbench.colorTheme": "Catppuccin Mocha",
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.fontAliasing": "auto",
  "workbench.iconTheme": "vscode-icons",
  "workbench.layoutControl.enabled": false,
  "workbench.navigationControl.enabled": false,
  "workbench.preferredDarkColorTheme": "Catppuccin Mocha",
  "workbench.tree.indent": 15,
  "workbench.colorCustomizations": {
    "statusBarItem.errorForeground": "#f38ba8",
    "statusBarItem.warningForeground": "#f9e2af",
    "statusBar.noFolderBackground": "#cba6f7",
    "statusBar.debuggingBackground": "#cba6f7",
    "statusBar.debuggingForeground": "#020617",
    "statusBar.background": "#cba6f7",
    "statusBar.foreground": "#020617"
  }
}
